<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Lazybones.Features.Shell"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="300"
        x:Class="Lazybones.Features.Shell.ModeSwitchDialog"
        x:DataType="vm:ModeSwitchDialogViewModel"
        Title="Mode Switch"
        Icon="/Assets/appicon.ico"
        SizeToContent="WidthAndHeight"
        MinWidth="400"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        WindowDecorations="BorderOnly"
        Background="#FF121212"
        Topmost="True">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#FF0078D4" />
            <Setter Property="Foreground" Value="#FFFFFFFF" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        
        <Style Selector="Button.primary">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, Auto, Auto" Margin="32">
        <TextBlock Grid.Row="0"
                   Text="Time to change position."
                   FontSize="14"
                   Foreground="#FFAAAAAA"
                   TextAlignment="Center"
                   Margin="0,0,0,12" />
        
        <TextBlock Grid.Row="1"
                   Text="{Binding Message}"
                   FontSize="40"
                   FontWeight="Black"
                   Foreground="#FFFFFFFF"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   LineHeight="48" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Margin="0,32,0,0">
            <Button Content="Start Now"
                    Classes="primary"
                    Width="140"
                    Height="56"
                    FontSize="16"
                    Command="{Binding StartNowCommand}" />
            <Button Content="Dismiss"
                    Width="140"
                    Height="56"
                    FontSize="16"
                    Command="{Binding DismissCommand}" />
        </StackPanel>
    </Grid>
</Window>
