<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lazybones.Features.Shell"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:Lazybones.Core.Behaviors"
        xmlns:controls="clr-namespace:Lazybones.Features.Stats"
        mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="260"
        x:Class="Lazybones.Features.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/appicon.ico"
        WindowDecorations="None"
        CanResize="False"
        Padding="0"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        BorderThickness="0"
        Topmost="{Binding AlwaysOnTop}"
        Width="300"
        Height="300"
        behaviors:DraggableWindowBehavior.EnableDrag="True">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <Window.Resources>
        <Color x:Key="BackgroundColor">#FF121212</Color>
        <Color x:Key="ForegroundColor">#FFFFFFFF</Color>
        <Color x:Key="BorderColor">#FF3A3A3A</Color>
        <Color x:Key="DisabledColor">#FF8E8E93</Color>
        <Color x:Key="AccentBackgroundColor">#FF0078D4</Color>
        <Color x:Key="AccentForegroundColor">#FFFFFFFF</Color>

        <StreamGeometry x:Key="PlayGeometry">M8 5v14l11-7z</StreamGeometry>
        <StreamGeometry x:Key="PauseGeometry">M6 19h4V5H6v14zm8-14v14h4V5h-4z</StreamGeometry>
        <StreamGeometry x:Key="ResetGeometry">M17.65 6.35A7.96 7.96 0 0 0 12 4a8 8 0 1 0 7.73 10H17.65A6 6 0 1 1 12 6c1.66 0 3.14.69 4.22 1.78L13 11h7V4z</StreamGeometry>
        <StreamGeometry x:Key="SwapGeometry">M16 17.01V10h-2v7.01h-3L15 21l4-3.99h-3zM9 3 5 6.99h3V14h2V6.99h3z</StreamGeometry>
        <StreamGeometry x:Key="CloseGeometry">M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</StreamGeometry>
        <StreamGeometry x:Key="MinimizeGeometry">M6 19h12v2H6z</StreamGeometry>
        <StreamGeometry x:Key="FlameGeometry">M19.48 12.35c-1.57-4.08-7.16-4.3-5.81-10.23.1-.44-.37-.78-.75-.55C9.29 3.71 6.68 8 8.87 13.62c.18.46-.36.89-.75.59-1.81-1.37-2-3.34-1.84-4.75.06-.52-.62-.77-.91-.34C4.69 10.16 4 11.84 4 14.37c.38 5.6 5.11 7.32 6.81 7.54 2.43.31 5.06-.14 6.95-1.87 2.08-1.93 2.84-5.01 1.72-7.69z</StreamGeometry>
        <StreamGeometry x:Key="StatsGeometry">M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z</StreamGeometry>
        <StreamGeometry x:Key="CoffeeGeometry">M2 21h18v-2H2v2zM20 8h-2V5H4v6c0 2.21 1.79 4 4 4h6c2.21 0 4-1.79 4-4v-3h2c1.1 0 2-.9 2-2v-2c0-1.11-.9-2-2-2zm0 4h-2v-2h2v2z</StreamGeometry>
        <StreamGeometry x:Key="SystemUpdateGeometry">M12 16.5 6 10.5l1.41-1.41L11 12.67V3h2v9.67l3.59-3.58L18 10.5l-6 6zm-9 1.5h18v2H3z</StreamGeometry>
        <StreamGeometry x:Key="TrophyGeometry">M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z</StreamGeometry>
        <StreamGeometry x:Key="SunriseGeometry">M6.76 4.84l-1.8-1.79-1.41 1.41 1.79 1.79 1.42-1.41zM4 10.5H1v2h3v-2zm9-9.95h-2V3.5h2V.55zm7.45 3.91-1.41-1.41-1.79 1.79 1.41 1.41 1.79-1.79zM17.24 18.16l1.79 1.8 1.41-1.41-1.8-1.79-1.4 1.4zM20 10.5v2h3v-2h-3zm-8-5c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm-1 16.95h2V19.5h-2v2.95zm-7.45-3.91 1.41 1.41 1.79-1.8-1.41-1.41-1.79 1.8z</StreamGeometry>
    </Window.Resources>

    <Window.Styles>

        <Style Selector=".timer.standing TextBlock.digits">
            <Setter Property="FontSize" Value="42" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector=".timer.standing TextBlock.separator">
            <Setter Property="FontSize" Value="42" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="Foreground" Value="{DynamicResource DisabledColor}" />
            <Setter Property="Margin" Value="4 0 4 0" />
        </Style>
        <Style Selector=".timer.standing TextBlock.text">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector=".timer.resting TextBlock.digits">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{DynamicResource DisabledColor}" />
        </Style>
        <Style Selector=".timer.resting TextBlock.separator">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="Foreground" Value="{DynamicResource DisabledColor}" />
            <Setter Property="Margin" Value="4 0 4 0" />
        </Style>
        <Style Selector=".timer.resting TextBlock.text">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Arial" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{DynamicResource DisabledColor}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- All Buttons in the main window get the pointer cursor — everything
             clickable should communicate "I'm clickable" via the hand cursor.
             Individual Buttons can override if needed (none currently do). -->
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Action buttons (play/reset/swap/stats/settings): dim by default,
             bright accent when the window is hovered. -->
        <Style Selector=".buttonpanel Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector=".buttonpanel Button PathIcon">
            <Setter Property="Foreground" Value="#FF4A4A4A" />
        </Style>
        <Style Selector="Window:pointerover .buttonpanel Button">
            <Setter Property="Background" Value="{DynamicResource AccentBackgroundColor}" />
        </Style>
        <Style Selector="Window:pointerover .buttonpanel Button PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundColor}" />
        </Style>

        <!-- Window controls (minimize/close): dim by default, bright on window hover. -->
        <Style Selector="Button.iconbutton">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0 0 0 0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.iconbutton PathIcon">
            <Setter Property="Foreground" Value="#FF4A4A4A" />
        </Style>
        <Style Selector="Window:pointerover Button.iconbutton PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>

        <Style Selector="PathIcon.btnicon">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
        </Style>

        <Style Selector="PathIcon.windowicon">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
        </Style>

        <Style Selector="StackPanel.windowpanel">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,24,0,0" />
            <Setter Property="Spacing" Value="8" />
        </Style>

    </Window.Styles>

    <Border Width="260" Height="260"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            CornerRadius="130" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
            Background="{DynamicResource BackgroundColor}" Padding="0"
            BoxShadow="0 4 12 0 #66000000">

        <Grid>
            <!-- Layered progress rings (visual only) -->
            <controls:ProgressRings
                IsHitTestVisible="False"
                OuterValue="{Binding OuterRingProgress}"
                InnerValue="{Binding InnerRingProgress}"
                IsStanding="{Binding IsStanding}" />

            <!-- Main Content -->
            <Grid RowDefinitions="Auto, *, Auto"
                  Classes="timer"
                  Classes.resting="{Binding !IsStanding}"
                  Classes.standing="{Binding IsStanding}">

                <!-- Timer centered in entire window - clickable -->
                <Button Grid.Row="0"
                        Grid.RowSpan="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        Command="{Binding AdjustTimeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Classes="digits" Text="{Binding Hours}" VerticalAlignment="Center" />
                        <TextBlock Classes="separator" Text=":" VerticalAlignment="Center" />
                        <TextBlock Classes="digits" Text="{Binding Minutes}" VerticalAlignment="Center" />
                        <TextBlock Classes="separator" Text=":" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Classes="digits" Text="{Binding Seconds}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Window controls at top-center -->
                <StackPanel Grid.Row="0" Classes="windowpanel">
                    <Button Classes="iconbutton minify"
                            Click="MinifyButton_OnClick">
                        <PathIcon Classes="windowicon" Data="{StaticResource MinimizeGeometry}" />
                    </Button>

                    <Button Classes="iconbutton close"
                            Click="CloseButton_OnClick">
                        <PathIcon Classes="windowicon" Data="{StaticResource CloseGeometry}" />
                    </Button>
                </StackPanel>

                <!-- Mode text below the window controls -->
                <TextBlock Grid.Row="0"
                           Margin="40,52,40,0"
                           Classes="text"
                           Text="{Binding Text}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top" />

                <!-- Streak indicator, just above the timer. Hidden when streak is 0.
                     Click opens the dashboard on the Stats tab. -->
                <Button Grid.Row="0"
                        Grid.RowSpan="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,72"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        IsVisible="{Binding HasStreak}"
                        Command="{Binding OpenStatsCommand}"
                        ToolTip.Tip="Daily standing-goal streak — consecutive days at or above your goal. Click to open Stats.">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <PathIcon Width="14" Height="14"
                                  Data="{StaticResource FlameGeometry}"
                                  Foreground="#FFFF8C42"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Streak}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#FFFF8C42"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Update indicator, just below the timer (mirrors the streak above).
                     Hidden when no update is ready. Click opens the dashboard on the
                     Updates tab. -->
                <Button Grid.Row="0"
                        Grid.RowSpan="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,72,0,0"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        IsVisible="{Binding HasUpdate}"
                        Command="{Binding OpenUpdatesCommand}"
                        ToolTip.Tip="A new version is ready — click for release notes and to restart">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <PathIcon Width="14" Height="14"
                                  Data="{StaticResource SystemUpdateGeometry}"
                                  Foreground="#FF4CC2FF"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AvailableVersionText}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#FF4CC2FF"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Action buttons, lifted above the bottom chord -->
                <StackPanel Grid.Row="2"
                            Margin="16,0,16,52"
                            Classes="buttonpanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Spacing="5">

                    <Button Classes="play"
                            ToolTip.Tip="Play/Pause"
                            Command="{Binding PlayPauseCommand}">
                        <Panel>
                            <PathIcon Classes="btnicon"
                                      IsVisible="{Binding !IsRunning}"
                                      Data="{StaticResource PlayGeometry}" />
                            <PathIcon Classes="btnicon"
                                      IsVisible="{Binding IsRunning}"
                                      Data="{StaticResource PauseGeometry}" />
                        </Panel>
                    </Button>
                    <Button Classes="reset"
                            ToolTip.Tip="Reset"
                            Command="{Binding ResetCommand}">
                        <PathIcon Classes="btnicon" Data="{StaticResource ResetGeometry}" />
                    </Button>
                    <Button Classes="swap"
                            ToolTip.Tip="Swap standing/resting"
                            Command="{Binding SwapCommand}">
                        <PathIcon Classes="btnicon" Data="{StaticResource SwapGeometry}" />
                    </Button>
                    <Button Classes="dashboard"
                            ToolTip.Tip="Stats, achievements &amp; settings"
                            Command="{Binding DashboardCommand}">
                        <PathIcon Classes="btnicon" Data="{StaticResource StatsGeometry}" />
                    </Button>

                </StackPanel>

                <!-- Achievement count, tucked beneath the action toolbar. Click opens
                     the dashboard on the Achievements tab. -->
                <Button Grid.Row="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,28"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding OpenAchievementsCommand}"
                        ToolTip.Tip="Achievements progress. Click to open the Achievements tab.">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <PathIcon Width="13" Height="13"
                                  Data="{StaticResource TrophyGeometry}"
                                  Foreground="#FFE6B450"
                                  VerticalAlignment="Center" />
                        <TextBlock Text="{Binding AchievementProgressText}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#FFE6B450"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Overlay with Blur Effect, clipped to the circle -->
            <Panel IsVisible="{Binding Overlay.IsVisible}">
                <Panel.Clip>
                    <EllipseGeometry Center="130,130" RadiusX="130" RadiusY="130" />
                </Panel.Clip>

                <!-- Blurred Background -->
                <ExperimentalAcrylicBorder IsHitTestVisible="False">
                    <ExperimentalAcrylicBorder.Material>
                        <ExperimentalAcrylicMaterial
                            BackgroundSource="Digger"
                            TintColor="#121212"
                            TintOpacity="0.8"
                            MaterialOpacity="0.9" />
                    </ExperimentalAcrylicBorder.Material>
                </ExperimentalAcrylicBorder>

                <!-- Content -->
                <Grid Margin="28,0,28,0">
                    <!-- Confirmation Dialog -->
                    <StackPanel IsVisible="{Binding Overlay.OverlayType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:OverlayType.Confirmation}}"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Overlay.Title}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding Overlay.Message}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <Button Content="Yes"
                                    Width="72"
                                    Height="32"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding ConfirmOverlayCommand}" />
                            <Button Content="No"
                                    Width="72"
                                    Height="32"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding CancelOverlayCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Idle Resume Toast (auto-dismiss, no buttons) -->
                    <StackPanel IsVisible="{Binding Overlay.OverlayType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:OverlayType.IdleResumeToast}}"
                                Spacing="6"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                            <PathIcon Width="18" Height="18"
                                      Data="{StaticResource CoffeeGeometry}"
                                      Foreground="#FF4CC2FF"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Welcome back"
                                       FontSize="11"
                                       Foreground="#FF4CC2FF"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Text="{Binding Overlay.Message}"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Day Rollover Toast (auto-dismiss, no buttons) -->
                    <StackPanel IsVisible="{Binding Overlay.OverlayType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:OverlayType.DayRolloverToast}}"
                                Spacing="6"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                            <PathIcon Width="18" Height="18"
                                      Data="{StaticResource SunriseGeometry}"
                                      Foreground="#FFFFD166"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Overlay.Title}"
                                       FontSize="11"
                                       Foreground="#FFFFD166"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Text="{Binding Overlay.Message}"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Achievement Toast (auto-dismiss, no buttons) -->
                    <StackPanel IsVisible="{Binding Overlay.OverlayType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:OverlayType.AchievementToast}}"
                                Spacing="6"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                            <PathIcon Width="18" Height="18"
                                      Data="{StaticResource FlameGeometry}"
                                      Foreground="#FFFFD166"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Achievement"
                                       FontSize="11"
                                       Foreground="#FFFFD166"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Text="{Binding Overlay.Title}"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding Overlay.Message}"
                                   FontSize="11"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Time Adjustment Dialog -->
                    <StackPanel IsVisible="{Binding Overlay.OverlayType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:OverlayType.TimeAdjustment}}"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Overlay.Title}"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   TextAlignment="Center" />

                        <StackPanel Spacing="4">
                            <TextBox Name="TimeInputBox"
                                     Text="{Binding Overlay.TimeInput}"
                                     TextAlignment="Center"
                                     FontSize="14"
                                     HorizontalAlignment="Stretch"
                                     PlaceholderText="30 or 5m or +2m"
                                     GotFocus="TimeInputBox_OnGotFocus" />
                            <TextBlock Text="Examples: 30, 1.5, +5m, -10s, 01:30:00"
                                       FontSize="9"
                                       Foreground="{DynamicResource DisabledColor}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Text="This cycle won't count toward achievements or streak."
                                   FontSize="10"
                                   Foreground="#FFE6B450"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    Margin="0,4,0,0">
                            <Button Content="Apply"
                                    Width="72"
                                    Height="30"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding ConfirmOverlayCommand}" />
                            <Button Content="Cancel"
                                    Width="72"
                                    Height="30"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding CancelOverlayCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Panel>
        </Grid>
    </Border>
</Window>
