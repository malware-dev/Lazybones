<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Lazybones.ViewModels"
        xmlns:controls="clr-namespace:Lazybones.Views.Controls"
        xmlns:behaviors="clr-namespace:Lazybones.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="560"
        x:Class="Lazybones.Views.DashboardWindow"
        x:DataType="vm:DashboardViewModel"
        Icon="/Assets/appicon.ico"
        Title="Get Up, Lazybones!"
        Width="480"
        Height="560"
        CanResize="False"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Color x:Key="BackgroundColor">#FF121212</Color>
        <Color x:Key="ForegroundColor">#FFFFFFFF</Color>
        <Color x:Key="BorderColor">#FF2A2A2A</Color>
        <Color x:Key="DisabledColor">#FF8E8E93</Color>
        <Color x:Key="AccentColor">#FF4CC2FF</Color>

        <StreamGeometry x:Key="CloseGeometry">M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</StreamGeometry>
        <StreamGeometry x:Key="MinimizeGeometry">M6 19h12v2H6z</StreamGeometry>
    </Window.Resources>

    <Window.Styles>
        <!-- Title-strip window controls: dim by default, bright on window hover -->
        <Style Selector="Button.iconbutton">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.iconbutton PathIcon">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Foreground" Value="#FF4A4A4A" />
        </Style>
        <Style Selector="Window:pointerover Button.iconbutton PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>

        <!-- Wordmark on the title strip -->
        <Style Selector="TextBlock.wordmark">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF6E6E6E" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!-- Custom flat tabs: no border box, just an accent underline on the
             selected one. -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF6E6E6E" />
            <Setter Property="Padding" Value="14,8,14,8" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <!-- Push the header text up off the bottom of the layout panel so the
             selected-pipe underline isn't smushed against the title. -->
        <Style Selector="TabItem /template/ ContentPresenter">
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#10FFFFFF" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="{DynamicResource AccentColor}" />
            <Setter Property="Height" Value="2" />
            <Setter Property="Margin" Value="5,0" />
        </Style>

        <!-- Labels & headings -->
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#FF8E8E93" />
        </Style>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF8E8E93" />
        </Style>

        <!-- Stat / achievement cards -->
        <Style Selector="Border.statcard">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="#FF1A1A1A" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#FF262626" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.achievement">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="#FF1A1A1A" />
            <Setter Property="BorderBrush" Value="#FF262626" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Border.achievement.unlocked">
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Background" Value="#FF152A1A" />
            <Setter Property="BorderBrush" Value="#FF2A4A33" />
        </Style>
    </Window.Styles>

    <!-- Outer grid hosts the rounded "card" with drop shadow, centered with
         20px transparent padding for the shadow to fall into. -->
    <Grid>
        <Border Width="440" Height="520"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="14"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                Background="{DynamicResource BackgroundColor}"
                BoxShadow="0 4 12 0 #66000000"
                ClipToBounds="True">
            <Grid RowDefinitions="36,*">

                <!-- Title strip: draggable, minimize/close on the right -->
                <Grid Grid.Row="0"
                      Background="Transparent"
                      behaviors:DraggableWindowBehavior.EnableDrag="True">
                    <TextBlock Classes="wordmark" Text="Get Up, Lazybones!" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="2"
                                Margin="0,0,8,0">
                        <Button Classes="iconbutton" Click="MinifyButton_OnClick">
                            <PathIcon Data="{StaticResource MinimizeGeometry}" />
                        </Button>
                        <Button Classes="iconbutton" Click="CloseButton_OnClick">
                            <PathIcon Data="{StaticResource CloseGeometry}" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Tabs -->
                <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">

                    <!-- ============================ STATS ============================ -->
                    <TabItem Header="Stats">
                        <StackPanel Spacing="16" Margin="18,12,18,18">

                            <Grid ColumnDefinitions="*,12,*">
                                <Border Grid.Column="0" Classes="statcard">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="label" Text="Today" />
                                        <TextBlock Classes="h1" Text="{Binding TodayProgressText}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="statcard">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="label" Text="Streak" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="h1"
                                                       Text="{Binding CurrentStreak}"
                                                       Foreground="#FFFF8C42" />
                                            <TextBlock Classes="muted"
                                                       Text="days"
                                                       VerticalAlignment="Bottom"
                                                       Margin="0,0,0,5" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="statcard">
                                <StackPanel Spacing="10">
                                    <TextBlock Classes="label" Text="Last 13 weeks (standing minutes per day)" />
                                    <controls:Heatmap MinutesByDay="{Binding HeatmapData}"
                                                      DailyGoalMinutes="{Binding DailyGoalMinutes}"
                                                      Width="370"
                                                      Height="110"
                                                      HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </TabItem>

                    <!-- ======================== ACHIEVEMENTS ======================== -->
                    <TabItem Header="Achievements">
                        <Grid RowDefinitions="Auto,*" Margin="18,12,18,18">
                            <TextBlock Grid.Row="0"
                                       Classes="muted"
                                       Text="{Binding UnlockedSummary}"
                                       Margin="0,0,0,10" />
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Achievements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:AchievementViewItem">
                                            <Border Classes="achievement" Classes.unlocked="{Binding IsUnlocked}">
                                                <StackPanel Spacing="3">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="✓"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FF66BB6A"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding IsUnlocked}" />
                                                        <TextBlock Classes="body"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding Title}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Classes="muted"
                                                               Text="{Binding Description}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ========================== SETTINGS ========================== -->
                    <TabItem Header="Settings">
                        <StackPanel Spacing="16" Margin="18,14,18,18">

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Standing time (minutes)" />
                                <NumericUpDown Value="{Binding StandingTime}"
                                               Minimum="1" Maximum="180" Increment="5"
                                               FormatString="0"
                                               HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Sitting time (minutes)" />
                                <NumericUpDown Value="{Binding SittingTime}"
                                               Minimum="1" Maximum="240" Increment="10"
                                               FormatString="0"
                                               HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="label" Text="Daily standing goal (minutes)" />
                                <NumericUpDown Value="{Binding DailyGoalMinutes}"
                                               Minimum="10" Maximum="720" Increment="15"
                                               FormatString="0"
                                               HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <CheckBox Content="{Binding StartWithOsLabel}"
                                      IsChecked="{Binding StartWithWindows}" />

                            <TextBlock Classes="muted"
                                       Text="Changes save automatically."
                                       Margin="0,4,0,0" />

                        </StackPanel>
                    </TabItem>

                    <!-- ========================== UPDATES =========================== -->
                    <TabItem Header="Updates">
                        <Grid Margin="18,12,18,18"
                              RowDefinitions="Auto,Auto,*,Auto"
                              RowSpacing="12">

                            <!-- Current version -->
                            <Border Grid.Row="0" Classes="statcard">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="label" Text="Running version" />
                                    <TextBlock Classes="h1" Text="{Binding CurrentVersionText}" />
                                </StackPanel>
                            </Border>

                            <!-- Status -->
                            <Border Grid.Row="1" Classes="statcard">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="label" Text="{Binding UpdateStatusLabel}" />
                                    <TextBlock Classes="body"
                                               Text="{Binding UpdateStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Release notes (only when an update is ready) -->
                            <Border Grid.Row="2"
                                    Classes="statcard"
                                    IsVisible="{Binding HasUpdateReady}">
                                <Grid RowDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0"
                                               Classes="label"
                                               Text="What's new"
                                               Margin="0,0,0,8" />
                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock Classes="body"
                                                   Text="{Binding ReleaseNotesText}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas,Menlo,monospace"
                                                   FontSize="12" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <!-- Actions -->
                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="8">
                                <Button Content="Check for updates"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        IsEnabled="{Binding CanCheckForUpdates}" />
                                <Button Content="Restart now"
                                        Command="{Binding RestartNowCommand}"
                                        IsVisible="{Binding HasUpdateReady}" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>
